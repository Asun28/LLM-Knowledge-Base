# Copy to .env and fill in your API keys

# Optional — Claude API. NOT needed when using Claude Code (MCP mode is the default LLM).
# Required ONLY for: (a) CLI `kb compile` / `kb query` without use_api=False,
# (b) MCP tool calls with use_api=True, (c) `kb_query --format=...` output adapters.
# See CLAUDE.md § MCP servers for details.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — for firecrawl web scraping (alternative to crawl4ai)
FIRECRAWL_API_KEY=

# Optional — for OpenAI embeddings if ever needed
OPENAI_API_KEY=

# Model tier overrides (cycle 4 item #26 — documented to close drift vs
# src/kb/config.py:65-69 and CLAUDE.md model-tier table). Uncomment and
# override to pin a different Anthropic model per tier. Values must be a
# valid Anthropic model ID (e.g. claude-opus-4-7, claude-sonnet-4-6,
# claude-haiku-4-5-20251001).
# CLAUDE_SCAN_MODEL=claude-haiku-4-5-20251001
# CLAUDE_WRITE_MODEL=claude-sonnet-4-6
# CLAUDE_ORCHESTRATE_MODEL=claude-opus-4-7

# ── Cycle 21: CLI subprocess backend ─────────────────────────────────────────
# Select which LLM backend call_llm / call_llm_json uses.
# Default: "anthropic" (uses ANTHROPIC_API_KEY via SDK — no change to existing behaviour).
# Other values: ollama, gemini, opencode, codex, kimi, qwen, deepseek, zai
# Each calls the corresponding CLI tool as a subprocess via stdin/stdout.
# KB_LLM_BACKEND=anthropic

# Per-tier model overrides for CLI backends (only Ollama uses these by default).
# Overrides the defaults in CLI_TOOL_MODELS for the active backend.
# KB_CLI_MODEL_SCAN=llama3.2
# KB_CLI_MODEL_WRITE=qwen2.5-coder:7b
# KB_CLI_MODEL_ORCHESTRATE=qwen2.5-coder:32b

# Per-backend API keys (injected into subprocess env, not argv):
# GEMINI_API_KEY=
# KIMI_API_KEY=
# QWEN_API_KEY=
# DEEPSEEK_API_KEY=
# ZAI_API_KEY=
